# Quicksand {{ name_title }} Base Image
#
# This Dockerfile creates a minimal {{ name_title }} system suitable for
# running as a quicksand VM guest.
#
# TODO: Customize this Dockerfile for your Linux distribution.
# See packages/quicksand-ubuntu/quicksand_ubuntu/docker/Dockerfile for a complete example.

# =============================================================================
# Stage 1: Build the Rust agent
# =============================================================================
# Use rust:alpine for musl (Alpine) or rust:bookworm for glibc (Ubuntu/Debian)
FROM rust:alpine AS agent-builder

RUN apk add --no-cache musl-dev

WORKDIR /build
COPY agent/Cargo.toml agent/Cargo.lock* ./
COPY agent/src ./src

RUN cargo build --release && \
    strip /build/target/release/quicksand-guest-agent

# =============================================================================
# Stage 2: Create the VM image
# =============================================================================
# TODO: Set the base Docker image (e.g., ubuntu:24.04, alpine:3.21, debian:12)
